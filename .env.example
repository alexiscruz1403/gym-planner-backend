# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=local
PORT=3000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local: use the Docker Compose instance
# Production: use a MongoDB Atlas connection string
MONGODB_URI=mongodb://localhost:27017/gym-planner

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use long random strings in production — never plain readable phrases
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-must-be-at-least-32-characters-long
JWT_REFRESH_SECRET=change-me-must-be-at-least-32-characters-long-refresh
JWT_EXPIRATION=900        # Access token TTL in seconds (900 = 15 min)
JWT_REFRESH_EXPIRATION=604800  # Refresh token TTL in seconds (604800 = 7 days)

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Obtain from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Register both local and production callback URLs in Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Obtain from: Cloudinary Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Frontend URL — used to redirect after Google OAuth callback
FRONTEND_URL=http://localhost:3001

# ─── MercadoPago ──────────────────────────────────────────────────────────────
# Obtain from: MercadoPago Developers → Your applications → Credentials
# Use TEST-... tokens for sandbox testing, APP_USR-... for production
MERCADOPAGO_ACCESS_TOKEN=TEST-your-access-token
# Webhook secret: generate a random string and set the same value in MercadoPago
# webhook configuration → Signature → Secret key
MERCADOPAGO_WEBHOOK_SECRET=change-me-webhook-secret

# ─── Mailer (SMTP) ────────────────────────────────────────────────────────────
# Gmail example: enable 2FA → Google Account → Security → App passwords → generate
# For production consider SendGrid, Resend, Postmark, etc.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@gym-planner.com

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Obtain from: https://aistudio.google.com/apikey
# Required in production; optional in local/development
GEMINI_API_KEY=your-gemini-api-key

# ─── Seed ─────────────────────────────────────────────────────────────────────
# Used by npm run seed:admin to create or promote the admin user
SEED_ADMIN_EMAIL=admin@gymplanner.dev
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-me-secure-admin-password